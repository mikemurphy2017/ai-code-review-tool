AI_PROVIDER=ollama

# Used when AI_PROVIDER=ollama
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Used when AI_PROVIDER=openai_compatible_local
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_OPENAI_MODEL=gpt-oss-20b
LOCAL_OPENAI_API_KEY=local

# Used when AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
